{
  "homepage": "https://nh60211as.github.io/DoujinMapMarker/",
  "private": true,
  "name": "doujin-map-marker",
  "version": "IF7.ACTIVE",
  "license": "BSD-3-Clause",
  "type": "module",
  "scripts": {
    "generate-data": "node --import=tsx ./generate-data-script-src/index.ts",
    "gen-data": "npm run generate-data",
    "sanitize-data": "node --import=tsx ./sanitize-data-script-src/index.ts",
    "san-data": "npm run sanitize-data",
    "gen-san-data": "npm run generate-data && npm run sanitize-data",
    "dev": "vite",
    "build": "vite build",
    "build:gh": "vite build",
    "serve": "http-server ./build --port 8080",
    "test": "vitest ./tests --run --coverage",
    "format": "prettier --config prettier.config.js  \"{generate-data-script-src,sanitize-data-script-src,src,tests}/**/*.{ts,tsx,js,jsx,css,json}\" data/TagList.ts package.json prettier.config.js tsconfig.json vite.config.ts --write"
  },
  "dependencies": {
    "preact": "10.29.1",
    "preact-iso": "^2.12.0",
    "preact-render-to-string": "^6.6.7",
    "react-debounce-input": "^3.3.0",
    "react-superstore": "^0.1.4",
    "string-similarity-js": "^2.1.4"
  },
  "devDependencies": {
    "@backrunner/url-cleaner": "0.1.0",
    "@preact/preset-vite": "^2.10.5",
    "@types/node": "^22.19.19",
    "@vitest/coverage-v8": "^4.1.6",
    "baseline-browser-mapping": "^2.10.29",
    "csv-parser": "^3.2.1",
    "eslint": "^9.39.4",
    "eslint-config-preact": "^2.0.0",
    "http-server": "^14.1.1",
    "joi": "^18.1.2",
    "prettier": "^3.8.3",
    "prettier-plugin-sort-imports": "^1.8.11",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vite": "^7.3.3",
    "vite-plugin-checker": "^0.13.0",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.6",
    "workbox-window": "^7.4.1"
  },
  "eslintConfig": {
    "extends": "preact"
  }
}
